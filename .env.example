# =============================================================================
# Xenko WhatsApp Agent — Environment Variables
# Copy these to Railway Dashboard → Service → Variables
# NEVER commit real secrets to Git
# =============================================================================

# --- Hermes Runtime (required) ---
HERMES_HOME=/app/.hermes
HERMES_NO_COLOR=1
LOG_LEVEL=info

# --- LLM: MiniMax (default for Xenko) ---
MODEL_PROVIDER=minimax
MODEL_NAME=MiniMax-M2.1
MINIMAX_API_KEY=your_minimax_api_key_here

# --- LLM: Alternative providers (uncomment ONE block) ---
# OPENROUTER_API_KEY=your_openrouter_key
# OPENAI_API_KEY=your_openai_key
# ANTHROPIC_API_KEY=your_anthropic_key

# --- Airtable CRM (required) ---
AIRTABLE_PAT=your_airtable_personal_access_token
AIRTABLE_BASE_ID=appPcG5glvZZ8dxVQ
AIRTABLE_LEADS_TABLE=tbltPK2QoQJ6LCptt
AIRTABLE_PEOPLE_TABLE=tblfogtDSlN3dMBBI
AIRTABLE_COMPANIES_TABLE=tblCTSMzQMrXFRK6Y
AIRTABLE_OPPORTUNITIES_TABLE=tblJBjdAbOSQj2NPc

# --- PostgreSQL / GBrain (required — from Railway Postgres plugin) ---
POSTGRES_HOST=your_railway_pg_host
POSTGRES_PORT=your_railway_pg_port
POSTGRES_DB=railway
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_railway_pg_password
GBRAIN_PG_HOST=your_railway_pg_host
GBRAIN_PG_PORT=your_railway_pg_port
GBRAIN_PG_DB=railway
GBRAIN_PG_USER=postgres

# --- WhatsApp (required) ---
WHATSAPP_ENABLED=true
WHATSAPP_MODE=bot
WHATSAPP_ALLOW_ALL_USERS=true
GATEWAY_ALLOW_ALL_USERS=true
HERMES_PRIVILEGED_PHONE=+94760193094

# Mount Railway volume at: /app/.hermes/platforms/whatsapp/session
# Or paste local session: WHATSAPP_SESSION_B64=<from scripts/pair-whatsapp-local.ps1>

# --- Optional: Twenty CRM (separate Railway project) ---
# TWENTY_API_KEY=your_twenty_jwt_api_key
# TWENTY_API_URL=https://your-twenty-app.up.railway.app

# --- Optional: Admin panel ---
# ADMIN_PASSWORD=change_me_strong_password
# SECRET_KEY=change_me_random_secret
